FRONTEND_PORT=80
PTKNOW_PORT=8080

FRONTEND_IMAGE=your-dockerhub-username/site-frontend
FRONTEND_TAG=latest
BACKEND_IMAGE=your-dockerhub-username/site-backend
BACKEND_TAG=latest

POSTGRES_PORT=5432
POSTGRES_DB=ptknow_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

PTKNOW_DATASOURCE_ADDRESS=postgres:5432
PTKNOW_DATASOURCE_NAME=ptknow_db
PTKNOW_DATASOURCE_USERNAME=postgres
PTKNOW_DATASOURCE_PASSWORD=change-me

JWT_ISSUER=ptknow
SECRET_JWT_KEY=change-this-to-a-long-random-32-char-secret
JWT_REFRESH_COOKIE_SECURE=true
JWT_REFRESH_COOKIE_SAME_SITE=Lax

APP_FILE_STORAGE_TYPE=LOCAL
APP_FILE_UPLOAD_DIR=/data/uploads
APP_FILE_S3_ENDPOINT=
APP_FILE_S3_REGION=us-east-1
APP_FILE_S3_BUCKET=
APP_FILE_S3_ACCESS_KEY=
APP_FILE_S3_SECRET_KEY=
APP_FILE_S3_PATH_STYLE_ACCESS_ENABLED=true
APP_FILE_S3_KEY_PREFIX=
APP_CORS_ALLOWED_ORIGINS=https://ptknow.ru,https://www.ptknow.ru
APP_RECAPTCHA_ENABLED=true
APP_RECAPTCHA_SECRET_KEY=
APP_RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
APP_RECAPTCHA_SCORE_THRESHOLD=0.5

MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-root-password

SECURITY_RATE_LIMIT_ENABLED=true
SECURITY_RATE_LIMIT_LOGIN_MAX=10
SECURITY_RATE_LIMIT_LOGIN_WINDOW=PT1M
SECURITY_RATE_LIMIT_REGISTER_MAX=5
SECURITY_RATE_LIMIT_REGISTER_WINDOW=PT5M
SECURITY_RATE_LIMIT_REFRESH_MAX=30
SECURITY_RATE_LIMIT_REFRESH_WINDOW=PT1M

JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC
